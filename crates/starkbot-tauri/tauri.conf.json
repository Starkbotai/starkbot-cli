{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/tauri/v2/tauri.conf.json",
  "productName": "StarkBot",
  "version": "0.1.9",
  "identifier": "com.starkbot.gui",
  "build": {
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "StarkBot",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
